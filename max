import java.util.Scanner;
public class Main{
    public static void main(String[] args){
        Scanner num= new Scanner (System.in);
        int a = num.nextInt();
        int b = num.nextInt();
        int c = num.nextInt();
        int max;
        if(a>=b && a>=c){
            max=a;
        }
        if(b>=a && b>=c){
            max=b;
        }
        else{
            max=c;
        }
        System.out.println(max);
    num.close();
    }
}
